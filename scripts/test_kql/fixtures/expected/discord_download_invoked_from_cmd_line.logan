('Log Source' = 'Windows Security Events' or 'Log Source' = 'Windows Event Security Logs') and ('Event ID' = '4688') and (('Process Name' like '*powershell.exe*' or 'Process Name' like '*powershell_ise.exe*' or 'Process Name' like '*cmd.exe*') or 'Command Line' like '*powershell*') and (('Command Line' like '*cdn.discordapp.com*' or 'Command Line' like '*moc.ppadrocsid.ndc*')) | fields Time, Entity, User, 'Process Name', 'Command Line'