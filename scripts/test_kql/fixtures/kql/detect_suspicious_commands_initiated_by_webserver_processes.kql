('Log Source' = 'SOC Windows Sysmon Logs' or 'Log Source' = 'Windows Security Events') and (((('Parent Process Name' in ('w3wp.exe', 'beasvc.exe', 'httpd.exe') or 'Parent Process Name' like 'tomcat*') or 'Parent Process Name' in ('w3wp.exe', 'beasvc.exe', 'httpd.exe') or 'Parent Process Name' like 'tomcat*')) and 'Process Name' in ('cmd.exe', 'powershell.exe')) and ('Command Line' like '*%temp%*' or 'Command Line' like '*wget*' or 'Command Line' like '*whoami*' or 'Command Line' like '*certutil*' or 'Command Line' like '*systeminfo*' or 'Command Line' like '*ping*' or 'Command Line' like '*ipconfig*' or 'Command Line' like '*timeout*') | stats unique('Process Name') as any_FileName, unique('Command Line') as set_ProcessCommandLine, unique('Parent Process Name') as any_InitiatingProcessFileName, unique('Parent Process Name') as any_InitiatingProcessParentFileName by Entity, 'Host Name (Server)'